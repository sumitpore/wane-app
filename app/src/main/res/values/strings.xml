    <string name="app_name">Wane</string>
    <string name="accessibility_service_description">Wane uses this service to gently cover other apps with a calming water animation during focus sessions. It only detects which app is in the foreground — it never reads screen content, passwords, or personal information. The full source is public: https://github.com/sumitpore/wane-app.git</string>
    <string name="open_source_url" translatable="false">https://github.com/sumitpore/wane-app</string>

