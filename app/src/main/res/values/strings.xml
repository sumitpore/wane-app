    <string name="notification_title">Silence distractions</string>
    <string name="notification_description">Wane can temporarily snooze notifications during your focus session, so nothing breaks your flow. Enable notification access to activate this. Wane is open source — you can verify the code at github.com/sumitpore/wane-app.</string>
